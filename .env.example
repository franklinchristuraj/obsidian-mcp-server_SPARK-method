# Server Configuration
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_API_KEY=create-your-own-key

# Public base URL of the server (used in OAuth discovery endpoints)
MCP_BASE_URL=https://your-domain.com

# Obsidian REST API Configuration
OBSIDIAN_API_URL=http://localhost:27123
OBSIDIAN_API_KEY=obsidian-api-key
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# OAuth token storage (SQLite file path)
TOKEN_DB_PATH=tokens.db

# Workspace scoping (see workspace_keys.json.example)
# Path to JSON mapping API keys and OAuth client IDs to allowed workspace folders
WORKSPACE_KEYS_PATH=workspace_keys.json
# Comma-separated scopes when a key/client has no entry in workspace_keys.json
MCP_DEFAULT_WORKSPACE_SCOPES=personal,passion,work

# Development Settings
MCP_LOG_LEVEL=DEBUG
MCP_ENABLE_CORS=true
